# ─────────────────────────────────────────────────────────────────────────────
# AbexWriter — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ────── Database ──────
# PostgreSQL connection string (Neon, Supabase, local, etc.)
DATABASE_URL=postgresql://user:password@host:5432/abexwriter

# ────── Application ──────
NODE_ENV=development
# Session secret for cookie signing (generate a random 32+ character string)
SESSION_SECRET=change-me-to-a-random-secret

# ────── Encryption ──────
# Used to encrypt stored BYOK API keys at rest (32-byte hex recommended)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# ────── Platform LLM Keys (optional) ──────
# If set, users can use "Platform" mode without adding their own keys.
# Leave empty/unset to disable platform mode for that provider.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
FIREWORKS_API_KEY=
COHERE_API_KEY=

# ────── AI Image Generation (optional) ──────
# Platform keys for image providers. Users can also BYOK.
# OPENAI_API_KEY is reused for DALL-E (set above)
STABILITY_API_KEY=
REPLICATE_API_TOKEN=

# ────── Platform Quotas ──────
# Maximum tokens per user per day when using platform keys (0 = unlimited)
PLATFORM_DAILY_TOKEN_LIMIT=500000

# ────── Server ──────
PORT=5000
HOST=0.0.0.0
